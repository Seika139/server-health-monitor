# =============================================================================
# server-health-monitor configuration
# =============================================================================

# Discord Webhook URL (required)
DISCORD_WEBHOOK_URL=""

# Server name displayed in alerts
SERVER_NAME="$(hostname)"

# -----------------------------------------------------------------------------
# Thresholds (alerts fire when value exceeds these)
# -----------------------------------------------------------------------------
CPU_THRESHOLD=80            # CPU usage %
MEMORY_THRESHOLD=80         # Memory usage %
SWAP_IO_THRESHOLD=200       # Swap I/O (pages/sec). 0 to disable
DISK_THRESHOLD=90           # Disk usage %
LOAD_THRESHOLD_MULTIPLIER=2 # Alert when load > (CPU cores * this value)

# -----------------------------------------------------------------------------
# Process health check
# -----------------------------------------------------------------------------
# Comma-separated list of process names to monitor (exact match via pgrep -x).
# Leave empty to disable. Example: "nginx,mysqld,sshd"
WATCH_PROCESSES=""

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log directory is fixed at /var/log/health-monitor (systemd ReadWritePaths constraint)
LOG_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Alert behavior
# -----------------------------------------------------------------------------
# Cooldown in seconds: suppress duplicate alerts of the same type
ALERT_COOLDOWN=300

# Number of top processes to include in alert messages
TOP_PROCESSES=5

# -----------------------------------------------------------------------------
# ACP session context monitoring (OpenClaw)
# -----------------------------------------------------------------------------
# Set to "true" to enable ACP session context window monitoring.
# Requires python3 and access to ~/.openclaw/ and ~/.claude/ directories.
ACP_MONITOR_ENABLED="false"

# Context window usage thresholds (0.0-1.0)
ACP_MONITOR_WARN=0.7
ACP_MONITOR_DANGER=0.85

# Override default session/project paths (leave empty for defaults)
# ACP_MONITOR_SESSIONS=""
# ACP_MONITOR_PROJECTS=""

# -----------------------------------------------------------------------------
# Heartbeat (external dead-man's switch)
# -----------------------------------------------------------------------------
# URL to ping on each successful monitor run.
# Leave empty to disable. Compatible with:
#   - Healthchecks.io  : https://hc-ping.com/<uuid>
#   - Uptime Kuma      : https://your-kuma/api/push/<token>?status=up&msg=OK
#   - BetterStack      : https://uptime.betterstack.com/api/v1/heartbeat/<id>
#   - Any URL that accepts GET or POST
HEARTBEAT_URL=""
HEARTBEAT_METHOD="GET"
